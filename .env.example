# ==============================================
# EJEMPLO DE CONFIGURACIÓN CGR LMS
# Copiar este archivo a .env y ajustar valores
# ==============================================

# App
NODE_ENV=development
PORT=5000

# Backend: Base de datos MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=cgr_user
DB_PASSWORD=secret_db_password
DB_NAME=cgr_lms

# Backend: Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend: Auth y sesión
SESSION_SECRET=super_secret_session_key
JWT_SECRET=super_secret_jwt_key
DEFAULT_ADMIN_EMAIL=admin@cgr.go.cr

# Backend: Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend: Correo SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu.usuario@cgr.go.cr
EMAIL_PASSWORD=your-email-password
EMAIL_FROM="Seguridad de la Información <seguridad.informacion@cgr.go.cr>"

# Backend / Frontend: URLs y CORS
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000
RATE_LIMIT_MAX=1000

# Frontend: Vite environment
VITE_API_URL=http://localhost:5000/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional / scripts
BACKEND_URL=http://localhost:5000
TEST_SESSION_COOKIE=
